rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Site content — readable by anyone, writable only by admin
    match /siteData/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "viximariakids@viximariakids.com";
    }

    // Newsletter — anyone can subscribe (write), admin can read
    match /newsletter/{document} {
      allow write: if true;
      allow read: if request.auth != null && request.auth.token.email == "viximariakids@viximariakids.com";
    }

    // Top-level orders — customer reads/creates own; admin full access; server via Cloud Functions
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.email == "viximariakids@viximariakids.com"
      );
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid ||
        request.auth.token.email == "viximariakids@viximariakids.com"
      );
      allow update, delete: if request.auth != null &&
        request.auth.token.email == "viximariakids@viximariakids.com";
    }

    // Customer profiles — customer reads/writes own; admin reads/writes all
    match /customers/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == "viximariakids@viximariakids.com"
      );

      // Orders subcollection — customer reads/creates own; admin full access
      match /orders/{orderId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.token.email == "viximariakids@viximariakids.com"
        );
        allow create: if request.auth != null && (
          request.auth.uid == userId ||
          request.auth.token.email == "viximariakids@viximariakids.com"
        );
        allow update, delete: if request.auth != null &&
          request.auth.token.email == "viximariakids@viximariakids.com";
      }
    }

    // Backups — admin only
    match /backups/{document} {
      allow read, write: if request.auth != null && request.auth.token.email == "viximariakids@viximariakids.com";
    }

    // Pages (page builder) — anyone reads published, admin writes
    match /pages/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "viximariakids@viximariakids.com";
    }
  }
}
